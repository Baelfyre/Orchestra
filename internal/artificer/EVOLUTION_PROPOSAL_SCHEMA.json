{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtificerEvolutionProposal",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.1"],
      "description": "The fixed schema version."
    },
    "proposal_id": {
      "type": "string",
      "description": "Unique identifier for the evolution proposal."
    },
    "title": {
      "type": "string",
      "description": "Short, descriptive title for the proposal."
    },
    "objective": {
      "type": "string",
      "description": "The main goal of the evolution."
    },
    "proposal_date": {
      "type": "string",
      "format": "date",
      "description": "Date the proposal entered the governed proposal lifecycle."
    },
    "source_audit_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of associated audit report IDs."
    },
    "selected_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "decision_id": { "type": "string" },
          "pattern_record_path": { "type": "string" },
          "target_component": { "type": "string" },
          "evolution_mechanism": {
            "type": "string",
            "enum": [
              "CONCEPTUAL_ADAPTATION",
              "SAFE_REWRITE",
              "DIRECT_REUSE_REVIEW_REQUIRED",
              "TEST_CORPUS_ADAPTATION"
            ]
          },
          "owner_specialist": { "type": "string" },
          "rationale": { "type": "string" }
        },
        "required": [
          "decision_id",
          "pattern_record_path",
          "target_component",
          "evolution_mechanism",
          "owner_specialist",
          "rationale"
        ],
        "additionalProperties": false
      }
    },
    "verification_plan": {
      "type": "string",
      "description": "How the implementation of this proposal will be verified."
    },
    "governance_handoff": {
      "type": "string",
      "description": "Information required for governance handover."
    },
    "reviews": {
      "type": "object",
      "properties": {
        "arbiter": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["NOT_REQUIRED", "PENDING", "APPROVED", "REVISION_REQUIRED", "BLOCKED"] },
            "rationale": { "type": "string" },
            "review_date": { "type": "string", "format": "date" }
          },
          "required": ["status", "rationale", "review_date"],
          "additionalProperties": false
        },
        "governor": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["NOT_REQUIRED", "PENDING", "APPROVED", "REVISION_REQUIRED", "BLOCKED"] },
            "rationale": { "type": "string" },
            "review_date": { "type": "string", "format": "date" }
          },
          "required": ["status", "rationale", "review_date"],
          "additionalProperties": false
        },
        "steward": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["NOT_REQUIRED", "PENDING", "APPROVED", "REVISION_REQUIRED", "BLOCKED"] },
            "rationale": { "type": "string" },
            "review_date": { "type": "string", "format": "date" }
          },
          "required": ["status", "rationale", "review_date"],
          "additionalProperties": false
        }
      },
      "required": ["arbiter", "governor", "steward"],
      "additionalProperties": false
    },
    "maintainer_decision": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PENDING", "APPROVED", "REVISION_REQUIRED", "DEFERRED", "REJECTED", "BLOCKED"]
        },
        "rationale": { "type": "string" },
        "decision_date": { "type": "string", "format": "date" }
      },
      "required": ["status", "rationale", "decision_date"],
      "additionalProperties": false
    },
    "proposal_status": {
      "type": "string",
      "enum": ["DRAFT", "UNDER_REVIEW", "APPROVED", "REVISION_REQUIRED", "DEFERRED", "REJECTED", "BLOCKED"],
      "description": "Overall status of the proposal."
    }
  },
  "required": [
    "schema_version",
    "proposal_id",
    "title",
    "objective",
    "proposal_date",
    "source_audit_ids",
    "selected_patterns",
    "verification_plan",
    "governance_handoff",
    "reviews",
    "maintainer_decision",
    "proposal_status"
  ],
  "additionalProperties": false
}
